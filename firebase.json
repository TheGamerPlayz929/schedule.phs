{
  "hosting": {
    "site": "poolesville",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=()"
          },
          {
            "key": "X-Robots-Tag",
            "value": "noindex, noarchive"
          },
          {
            "key": "Content-Security-Policy",
            "value": "base-uri 'self'; object-src 'none'; frame-ancestors 'self' https://phs-grades-backend.onrender.com https://poolesville.web.app https://poolesville.firebaseapp.com https://schedulephs.web.app https://schedulephs.firebaseapp.com https://thegamerplayz929.github.io"
          }
        ]
      },
      {
        "source": "/site-settings.json",
        "headers": [
          { "key": "Cache-Control", "value": "no-store, max-age=0" }
        ]
      },
      {
        "source": "/data.json",
        "headers": [
          { "key": "Cache-Control", "value": "no-store, max-age=0" }
        ]
      }
    ]
  }
}
